    },
    {
      "parameters": {
        "jsCode": "// Summary\nconst allItems = $('Create Launch').all();\nconst createdItems = $('Capture Initial State').all();\n\nreturn [{\n  json: {\n    run_completed_at: new Date().toISOString(),\n    horizon_signals_processed: allItems.length,\n    launches_created: createdItems.length,\n    launch_ids: createdItems.map(i => i.json.launch_id).filter(Boolean)\n  }\n}];"
      },
      "id": "e6157024-a3ae-4438-90dd-2d8d55c0dcd6",
      "name": "Run Summary",
      "type": "n8n-nodes-base.code",
      "position": [
        1200,
        0
      ],
      "typeVersion": 2
    }
  ],
