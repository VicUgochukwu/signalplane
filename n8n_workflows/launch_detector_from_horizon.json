      ],
      "typeVersion": 2.5,
      "credentials": {
        "postgres": {
          "id": "R4dqt2sDzMKpQu7a",
          "name": "Supabase Postgres"
        }
      },
      "retryOnFail": true,
      "maxTries": 2,
      "waitBetweenTries": 500
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "launch_created",
              "leftValue": "={{ $json.launch_id }}",
              "rightValue": "",
              "operator": {
                "type": "string",
                "operation": "notEmpty"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "9f1ab5d1-d4e9-4465-8fdd-a36da36bc675",
      "name": "Launch Created?",
      "type": "n8n-nodes-base.filter",
      "position": [
        800,
        0
      ],
      "typeVersion": 2
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT launch_tracker.capture_initial_state('{{ $json.launch_id }}'::UUID) AS captured;",
        "options": {}
      },
      "id": "c7888467-a068-4b54-b950-0989a938e019",
      "name": "Capture Initial State",
      "type": "n8n-nodes-base.postgres",
      "position": [
        1008,
        0
      ],
      "typeVersion": 2.5,
      "credentials": {
        "postgres": {
          "id": "R4dqt2sDzMKpQu7a",
