    {
      "id": "collect-all-narratives",
      "name": "Collect All Narratives",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1760,
        400
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// After all pages processed, gather all narrative snapshots for drift analysis\nconst items = $input.all().map(i => i.json);\n// Group by company\nconst byCompany = {};\nfor (const item of items) {\n  const key = item.company_id || item.tracked_page_id;\n  if (!byCompany[key]) byCompany[key] = { items: [], company_name: '' };\n  if (Array.isArray(item)) {\n    item.forEach(r => {\n      byCompany[r.company_id] = byCompany[r.company_id] || {items:[], company_name: r.company_name || ''};\n      byCompany[r.company_id].items.push(r);\n    });\n  } else {\n    byCompany[key].items.push(item);\n    byCompany[key].company_name = item.company_name || byCompany[key].company_name;\n  }\n}\n// Pass all upserted snapshots forward as single item for next phase\nreturn [{json: {phase: 'drift_detection', snapshot_count: items.length, message: 'Ready for drift detection'}}];"
      }
    },
