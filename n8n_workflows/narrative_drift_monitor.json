    {
      "id": "merge-pages-snapshots",
      "name": "Merge Pages + Snapshots",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        880,
        400
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "\n// Get pages from the first node\nconst pages = $('Get Active Pages').all().map(i => i.json);\nconst snapshots = $('Get This Week Snapshots').all().map(i => i.json);\n\n// Build a lookup of snapshots by tracked_page_id\nconst snapMap = {};\nfor (const snap of snapshots) {\n  if (!snapMap[snap.tracked_page_id]) {\n    snapMap[snap.tracked_page_id] = snap;\n  }\n}\n\n// Join: for each page, find its latest snapshot\nconst results = [];\nfor (const page of pages) {\n  const snap = snapMap[page.id];\n  if (snap) {\n    results.push({\n      json: {\n        page_id: page.id,\n        company_id: page.company_id,\n        company_name: page.company_name,\n        url: page.url,\n        url_type: page.url_type,\n        snapshot_id: snap.id,\n        tracked_page_id: snap.tracked_page_id,\n        text_content: snap.text_content || '',\n        raw_html: snap.raw_html || snap.text_content || '',\n        week_start_date: snap.week_start_date\n      }\n    });\n  }\n}\n\nreturn results;\n"
      }
    },
    {
      "id": "llm-extract-copy",
      "name": "LLM: Extract Copy",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1100,
        400
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "tiqqmgq14G2sygfA",
          "name": "Anthropic API Key"
        }
      },
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "authentication": "genericCredentialType",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "anthropic-version",
              "value": "2023-06-01"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ model: \"claude-sonnet-4-20250514\", max_tokens: 1500, system: \"Extract only the core value proposition text (hero headline, subhead, pricing headline) from the following page text. Remove navigation, testimonials, UI labels, legal text. Return clean text only, no JSON.\", messages: [{ role: \"user\", content: $json.text_content || $json.raw_html || \"No content\" }] }) }}",
        "genericAuthType": "httpHeaderAuth"
      }
    },
    {
      "id": "parse-extract",
      "name": "Parse Extract + Hash",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1320,
        400
      ],
      "parameters": {
        "jsCode": "function fnv1a64(str) {\n  let h1 = 0x811c9dc5 >>> 0;\n  let h2 = 0xcbf29ce4 >>> 0;\n  for (let i = 0; i < str.length; i++) {\n    const c = str.charCodeAt(i);\n    h1 = Math.imul(h1 ^ c, 0x01000193) >>> 0;\n    h2 = Math.imul(h2 ^ (c >> 8 | c), 0x01000193) >>> 0;\n  }\n  return h2.toString(16).padStart(8, '0') + h1.toString(16).padStart(8, '0');\n}\n\nconst input = $input.first().json;\nconst prev = $('Merge Pages + Snapshots').first().json;\nlet text = input.content?.[0]?.text || '';\nconst fenceMatch = text.match(/```(?:\\w*)\\s*([\\s\\S]*?)```/);\nif (fenceMatch) text = fenceMatch[1].trim();\nconst hash = fnv1a64(text);\nreturn [{json: {\n  tracked_page_id: prev.tracked_page_id,\n  company_id: prev.company_id,\n  company_name: prev.company_name,\n  url_type: prev.url_type,\n  week_start_date: prev.week_start_date,\n  extracted_copy: text,\n  copy_hash: hash\n}}];"
      }
    },
