        "jsonBody": "={{ JSON.stringify({ model: \"claude-sonnet-4-20250514\", max_tokens: 1500, system: \"Compare previous and current value proposition text for this company. Identify if there is a meaningful narrative shift. Classify drift direction: Outcome, Control, Speed, Intelligence, Risk, Trust, Platform, Simplicity. Return valid JSON only: {changed: bool, drift_from: string, drift_to: string, drift_direction: string, gtm_implication: string, severity: 1-5}\", messages: [{ role: \"user\", content: \"Previous copy:\\n\" + ($json.previous_copy || \"N/A\") + \"\\n\\nCurrent copy:\\n\" + ($json.current_copy || \"N/A\") }] }) }}",
