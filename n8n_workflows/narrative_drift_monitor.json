        1540,
        400
      ],
      "credentials": {
        "supabaseApi": {
          "id": "LLNegs5ACcYZC3K1",
          "name": "Supabase – Messaging Tracker"
        }
      },
      "parameters": {
        "method": "POST",
        "url": "https://dnqjzgfunvbofsuibcsk.supabase.co/rest/v1/narrative_snapshots?on_conflict=tracked_page_id,week_start_date",
