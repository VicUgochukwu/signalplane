    {
      "id": "parse-drift",
      "name": "Parse Drift Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2860,
        300
      ],
      "parameters": {
        "jsCode": "const raw = $input.first().json;\nconst prev = $('Filter: Has Drift?').first().json;\nlet text = raw.content?.[0]?.text || '{}';\nconst fm = text.match(/```(?:\\w*)\\s*([\\s\\S]*?)```/);\nif (fm) text = fm[1].trim();\nlet c;\ntry { c = JSON.parse(text); } catch(e) { c = {drift_detected: false}; }\nreturn [{json: {\n  company_id: prev.company_id,\n  week_start_date: prev.week_start_date,\n  drift_detected: c.drift_detected || false,\n  drift_from: c.drift_from || null,\n  drift_to: c.drift_to || null,\n  drift_direction: c.drift_direction || null,\n  scope: 'single_company',\n  gtm_implication: c.gtm_implication || null,\n  severity: c.severity || 1,\n  raw_llm_response: c\n}}];"
      }
