    {
      "id": "build-drift-prompts",
      "name": "Build Drift Prompts",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2200,
        400
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const snapshots = $input.all().map(i => i.json);\n// Group by company_id\nconst byCompany = {};\nfor (const s of snapshots) {\n  if (!byCompany[s.company_id]) byCompany[s.company_id] = [];\n  byCompany[s.company_id].push(s);\n}\nconst results = [];\nconst allCompanyCopy = [];\nfor (const [companyId, snaps] of Object.entries(byCompany)) {\n  snaps.sort((a,b) => b.week_start_date.localeCompare(a.week_start_date));\n  const current = snaps[0];\n  const previous = snaps.length > 1 ? snaps[1] : null;\n  allCompanyCopy.push({company_id: companyId, current_copy: current.extracted_copy, week: current.week_start_date});\n  if (previous && current.copy_hash !== previous.copy_hash) {\n    results.push({json: {\n      company_id: companyId,\n      week_start_date: current.week_start_date,\n      current_copy: current.extracted_copy,\n      previous_copy: previous.extracted_copy,\n      changed: true\n    }});\n  } else {\n    results.push({json: {\n      company_id: companyId,\n      week_start_date: current.week_start_date,\n      current_copy: current.extracted_copy,\n      previous_copy: previous ? previous.extracted_copy : '',\n      changed: false\n    }});\n  }\n}\n// Store all company copy for category analysis as last item\nresults.push({json: {\n  _is_category_data: true,\n  all_company_copy: allCompanyCopy,\n  week_start_date: snapshots[0]?.week_start_date || new Date().toISOString().slice(0,10)\n}});\nreturn results;"
      }
    },
